# Environment Variables Template
# Kopiraj kao .env i popuni vrijednosti

# ============================================
# DEVELOPMENT (Local)
# ============================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001

# Database (MySQL - local)
ConnectionStrings__MainDB=Server=localhost;Port=3306;Database=real_estate;User=root;Password=

# JWT Settings
JWTSettings__securityKey=7T-d1gfnZ_RqrWVHQYOo8ESZXDwwvPQ8ymWNGqFEm0c
JWTSettings__validIssuer=localhost:5000
JWTSettings__validAudience=localhost:7000
JWTSettings__expiryInMinutes=10

# ============================================
# PRODUCTION (Render.com)
# ============================================
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://+:10000

# Database (PostgreSQL - Render)
# ConnectionStrings__MainDB=postgresql://user:password@host:port/database

# JWT Settings - Production
# JWTSettings__securityKey=GENERATE_NEW_KEY_FOR_PRODUCTION
# JWTSettings__validIssuer=https://myproperty-api.onrender.com
# JWTSettings__validAudience=https://myproperty-ui.onrender.com
# JWTSettings__expiryInMinutes=10
